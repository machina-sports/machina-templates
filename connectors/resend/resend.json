{
  "openapi": "3.0.3",
  "info": {
    "title": "Resend",
    "description": "Transactional email API. Authenticate every request with `Authorization: Bearer <API key>`. The free tier sends from `onboarding@resend.dev` without domain verification — use that as the `from` address for smoke tests. Production sends require a verified domain.\n\nRATE LIMITS (Resend free tier): 100 emails/day, 2 requests/second. Exceeding returns HTTP 429 with body `{\"name\": \"rate_limit_exceeded\", \"message\": \"...\"}`. Paid tiers raise limits to 50,000+ emails/day.\n\nThe API also rejects sends with a 422 validation error when `from` is unverified for a non-sandbox domain — fix by verifying the domain in the Resend dashboard.",
    "version": "1.0.0",
    "contact": {
      "name": "Resend",
      "url": "https://resend.com/docs"
    }
  },
  "servers": [
    {
      "url": "https://api.resend.com",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API key"
      }
    },
    "schemas": {
      "Attachment": {
        "type": "object",
        "description": "Email attachment. Provide either `path` (HTTPS URL the server fetches) OR `content` (base64-encoded raw bytes) — not both. The free tier rejects payloads over 25MB total.",
        "properties": {
          "filename": {
            "type": "string",
            "example": "weekly-report.pdf"
          },
          "content": {
            "type": "string",
            "description": "Base64-encoded file content (no data URI prefix). Use when the file isn't reachable via a public URL.",
            "example": "JVBERi0xLjQKJeLjz9MK..."
          },
          "path": {
            "type": "string",
            "description": "Public HTTPS URL Resend fetches and attaches. Easier than base64 when the file already lives on GCS / S3 / CDN.",
            "example": "https://storage.googleapis.com/.../report.pdf"
          },
          "content_type": {
            "type": "string",
            "example": "application/pdf"
          }
        }
      }
    }
  },
  "paths": {
    "/emails": {
      "post": {
        "summary": "Send a transactional email",
        "description": "Sends one email synchronously. Returns the Resend `id` on success (use it to look up delivery status later via /emails/{id}). The recipient list (`to`) accepts up to 50 entries per call; for larger blasts use `/emails/batch` (not wired here yet).",
        "operationId": "post-emails",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["from", "to", "subject"],
                "properties": {
                  "from": {
                    "type": "string",
                    "description": "Sender. Format: `Display Name <local@verified-domain.com>` or just `local@verified-domain.com`. For unverified sends use `onboarding@resend.dev`.",
                    "example": "Machina Reports <reports@machinasports.com>"
                  },
                  "to": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Recipient email(s). Max 50 per call.",
                    "example": ["mateus@machinasports.com"]
                  },
                  "cc": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "bcc": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "reply_to": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "subject": {
                    "type": "string",
                    "example": "Weekly Token Report · Sports Interaction · 2026-05-20"
                  },
                  "html": {
                    "type": "string",
                    "description": "HTML body. Resend renders this verbatim — provide an inline-styled string (no external stylesheets are loaded by mail clients).",
                    "example": "<h1>Weekly report</h1><p>PDF attached.</p>"
                  },
                  "text": {
                    "type": "string",
                    "description": "Plain-text fallback. Most clients render `html` and fall back to `text` only when HTML is disabled."
                  },
                  "attachments": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Attachment" }
                  },
                  "tags": {
                    "type": "array",
                    "description": "Key/value labels Resend attaches to the message for filtering in the dashboard.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "value": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Email accepted for delivery",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "example": "4ef9a417-2f95-4e0c-9b3a-1c5d8a7b9e3f"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation error (unverified `from`, bad email format, etc.)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          "429": {
            "description": "Rate-limited (free tier: 100/day, 2/sec)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "example": "rate_limit_exceeded" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/emails/{email_id}": {
      "get": {
        "summary": "Get email delivery status",
        "description": "Look up delivery status of a previously-sent email by its Resend `id`. Useful for audit / retry workflows.",
        "operationId": "get-emails-id",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "email_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Email record",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "from": { "type": "string" },
                    "to": { "type": "array", "items": { "type": "string" } },
                    "subject": { "type": "string" },
                    "created_at": { "type": "string", "format": "date-time" },
                    "last_event": { "type": "string", "description": "delivered / bounced / complained / opened / clicked / etc." }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
